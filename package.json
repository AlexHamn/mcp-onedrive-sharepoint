{
  "name": "mcp-onedrive-sharepoint",
  "version": "1.1.0",
  "description": "MCP server for OneDrive/SharePoint integration",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc --pretty false",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "start": "node build/index.js",
    "stdio": "./scripts/run-stdio.sh",
    "spcall": "./scripts/spcall.sh",
    "setup-auth": "tsx src/auth/setup-auth.ts",
    "test": "npm run build && node --test build/tests/*.test.js",
    "lint": "eslint . --max-warnings 410",
    "ci": "npm run build && npm run lint && npm test",
    "format": "prettier --write \"src/**/*.ts\" README.md docs/**/*.md scripts/*.mjs"
  },
  "keywords": [
    "mcp",
    "onedrive",
    "sharepoint",
    "microsoft-graph"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "@github/keytar": "^7.10.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.7",
    "dotenv": "^17.4.2",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.0",
    "globals": "^17.6.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "bin": {
    "mcp-onedrive-sharepoint": "./build/index.js",
    "ods": "./build/cli.js",
    "sharepoint-mcp-stdio": "./scripts/run-stdio.sh",
    "spcall": "./scripts/spcall.sh"
  }
}
